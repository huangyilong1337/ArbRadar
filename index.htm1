<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ArbRadar</title>

    <link rel="stylesheet" href="style.css">
</head>

<body>

<div class="header">
    <h1>📈 ArbRadar</h1>

    <p>个人 LOF 套利雷达</p>

    <div class="time">
        更新时间：
        <span id="time">--</span>
    </div>
</div>

<div class="card">
    <h2>今日套利机会</h2>

    <table border="1" cellspacing="0" cellpadding="8" width="100%">
        <thead>
            <tr>
                <th>代码</th>
                <th>名称</th>
                <th>溢价率</th>
                <th>成交额</th>
                <th>限购</th>
                <th>交收</th>
                <th>评分</th>
            </tr>
        </thead>

        <tbody id="fundTable">
        </tbody>

    </table>
</div>

<script src="data.js"></script>
<script src="app.js"></script>

</body>
</html>
